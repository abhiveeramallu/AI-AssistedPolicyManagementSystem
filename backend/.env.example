NODE_ENV=development
PORT=5050
CORS_ORIGIN=http://localhost:5173

ACCESS_JWT_SECRET=replace_with_a_long_random_secret_for_user_auth
ACCESS_JWT_EXPIRES_IN=1h
FILE_TOKEN_SECRET=replace_with_another_long_random_secret_for_file_tokens
FILE_TOKEN_EXPIRES_IN=30m

MASTER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTED_STORAGE_PATH=./storage/encrypted
LOCAL_DB_PATH=./storage/local-db.json
MAX_FILE_SIZE_MB=15
ALLOWED_FILE_TYPES=application/pdf,image/png,image/jpeg,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ENABLE_DEV_AUTH_ENDPOINT=true
BOOTSTRAP_LOGIN_EMAIL=admin@secure-policy.local
BOOTSTRAP_LOGIN_PASSWORD=change_me_to_a_strong_password
BOOTSTRAP_LOGIN_ROLE=admin
